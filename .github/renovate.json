{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard"
  ],
  "packageRules": [
    {
      "description": "Ignore patch and digest updates to save CI resources",
      "matchUpdateTypes": [
        "patch",
        "digest",
        "pin"
      ],
      "enabled": false
    },
    {
      "description": "Group all major updates into a single PR for manual review",
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "all major updates",
      "automerge": false,
      "assignees": [
        "Andrewnplus"
      ]
    },
    {
      "description": "Group gradle wrappers and plugins",
      "matchPackagePatterns": [
        "gradle"
      ],
      "groupName": "gradle dependencies"
    },
    {
      "description": "Specific grouping for Hugo",
      "matchPackagePatterns": [
        "hugo"
      ],
      "groupName": "hugo updates"
    },
    {
      "matchPackageNames": [
        "github.com/Andrewnplus/nplus-book-core"
      ],
      "matchDepTypes": [
        "indirect"
      ],
      "groupName": "nplus book core",
      "enabled": true
    }
  ],
  "gomod": {
    "enabled": true,
    "postUpdateOptions": [
      "gomodTidy"
    ]
  },
  "gradle-wrapper": {
    "enabled": true
  },
  "regexManagers": [
    {
      "description": "Update Hugo version in build.gradle.kts",
      "fileMatch": [
        "^build\\.gradle\\.kts$"
      ],
      "matchStrings": [
        "version\\.set\\(\"(?<currentValue>.*?)\"\\)"
      ],
      "depNameTemplate": "gohugoio/hugo",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Update Hugo version in GitHub Actions (deploy.yml)",
      "fileMatch": [
        "^\\.github/workflows/.*\\.yml$"
      ],
      "matchStrings": [
        "hugo-version: ['\"]?(?<currentValue>[0-9.]+)['\"]?"
      ],
      "depNameTemplate": "gohugoio/hugo",
      "datasourceTemplate": "github-releases"
    }
  ],
  "assignees": [],
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "timezone": "Asia/Taipei",
  "automerge": true,
  "major": {
    "automerge": false,
    "assignees": [
      "Andrewnplus"
    ]
  }
}
